{
  "code": "rev_1_sci",
  "title": "திருப்புதல் தேர்வு 1 - அறிவியல் (Science)",
  "sections": [
    {
      "title": "அறிவியல் (Science) - பாடக்குறிப்பு",
      "content": "இயற்பியல், வேதியியல் மற்றும் உயிரியல் பாடங்களில் உள்ள அடிப்படை விதிகள் மற்றும் அலகுகள் (Units) குறித்த தொகுப்பு."
    }
  ],
  "quiz": {
    "questions": [
      { "section": "அறிவியல்", "question": "விசையின் SI அலகு (SI Unit of Force) என்ன?", "options": ["ஜூல்", "நியூட்டன்", "வாட்", "பாஸ்கல்"], "answer": 1, "ex": "விசியின் அலகு நியூட்டன் (N)." },
      { "section": "அறிவியல்", "question": "மனித உடலின் சராசரி வெப்பநிலை எவ்வளவு?", "options": ["37°C", "98.4°C", "30°C", "100°C"], "answer": 0, "ex": "சராசரியாக 37 டிகிரி செல்சியஸ்." },
      { "section": "அறிவியல்", "question": "ஒலியானது (Sound) எதன் வழியே பரவாது?", "options": ["திடப்பொருள்", "திரவப்பொருள்", "வாயு", "வெற்றிடம்"], "answer": 3, "ex": "ஒலி பரவ ஊடகம் தேவை, வெற்றிடத்தில் பரவாது." },
      { "section": "அறிவியல்", "question": "மின் தடையின் (Resistance) அலகு என்ன?", "options": ["ஆம்பியர்", "வோல்ட்", "ஓமி", "கூலூம்"], "answer": 2, "ex": "மின்தடையின் அலகு ஓம் ஆகும்." },
      { "section": "அறிவியல்", "question": "சூரிய ஒளியில் உள்ள ஏழு நிறங்களை பிரித்துக் காட்டுவது எது?", "options": ["ஆடி", "முப்பட்டகம்", "லென்ஸ்", "தொலைநோக்கி"], "answer": 1, "ex": "முப்பட்டகம் (Prism) நிறப்பிரிகையை ஏற்படுத்தும்." },
      { "section": "அறிவியல்", "question": "எலுமிச்சையில் உள்ள அமிலம் எது?", "options": ["அசிட்டிக் அமிலம்", "லாக்டிக் அமிலம்", "சிட்ரிக் அமிலம்", "டார்டாரிக் அமிலம்"], "answer": 2, "ex": "சிட்ரஸ் பழங்களில் சிட்ரிக் அமிலம் இருக்கும்." },
      { "section": "அறிவியல்", "question": "தூய நீரின் pH மதிப்பு என்ன?", "options": ["0", "7", "14", "5"], "answer": 1, "ex": "நடுநிலை நீரின் pH 7 ஆகும்." },
      { "section": "அறிவியல்", "question": "சலவைச் சோடாவின் (Washing Soda) வேதியியல் பெயர் என்ன?", "options": ["சோடியம் பைகார்பனேட்", "சோடியம் குளோரைடு", "சோடியம் கார்பனேட்", "கால்சியம் கார்பனேட்"], "answer": 2, "ex": "சோடியம் கார்பனேட் சலவைச் சோடா எனப்படும்." },
      { "section": "அறிவியல்", "question": "இயற்கையில் கிடைக்கும் மிகவும் கடினமான பொருள் எது?", "options": ["இரும்பு", "தங்கம்", "வைரம்", "பிளாட்டினம்"], "answer": 2, "ex": "வைரம் மிகக் கடினமானது." },
      { "section": "அறிவியல்", "question": "இரும்பு துருப்பிடித்தல் என்பது எவ்வகை மாற்றம்?", "options": ["இயற்பியல் மாற்றம்", "வேதியியல் மாற்றம்", "மீள் மாற்றம்", "வேகமான மாற்றம்"], "answer": 1, "ex": "புதிய பொருள் உருவாவதால் இது வேதியியல் மாற்றம்." },
      { "section": "அறிவியல்", "question": "செல்லின் 'ஆற்றல் மையம்' (Powerhouse of the cell) என அழைக்கப்படுவது எது?", "options": ["நியூக்ளியஸ்", "ரைபோசோம்", "மைட்டோகாண்ட்ரியா", "கோல்கை உறுப்புகள்"], "answer": 2, "ex": "மைட்டோகாண்ட்ரியா ஆற்றலை உருவாக்குகிறது." },
      { "section": "அறிவியல்", "question": "தாவரங்கள் ஒளிச்சேர்க்கையின் போது எந்த வாயுவை உள்ளிழுக்கின்றன?", "options": ["ஆக்சிஜன்", "கார்பன் டை ஆக்சைடு", "நிறுஜன்", "ஹைட்ரஜன்"], "answer": 1, "ex": "கார்பன் டை ஆக்சைடை உள்ளிழுக்கின்றன." },
      { "section": "அறிவியல்", "question": "மனித உடலில் உள்ள மிக நீளமான எலும்பு எது?", "options": ["முள்ளெலும்பு", "தொடை எலும்பு (Femur)", "விலா எலும்பு", "முழங்கை எலும்பு"], "answer": 1, "ex": "தொடை எலும்பு மிக நீளமானது." },
      { "section": "அறிவியல்", "question": "வைட்டமின் C குறைபாட்டினால் ஏற்படும் நோய் எது?", "options": ["மாலைக்கண் நோய்", "ரிக்கெட்ஸ்", "ஸ்கர்வி", "பெரிபெரி"], "answer": 2, "ex": "வைட்டமின் C குறைவால் ஸர்வி ஏற்படும்." },
      { "section": "அறிவியல்", "question": "'உலகளாவிய கொடையாளி' (Universal Donor) எனப்படும் இரத்த வகை எது?", "options": ["A", "B", "AB", "O"], "answer": 3, "ex": "O பிரிவு இரத்தத்தை யாருக்கு வேண்டுமானாலும் வழங்கலாம்." },
      { "section": "அறிவியல்", "question": "பாலில் உள்ள சர்க்கரையின் பெயர் என்ன?", "options": ["குளுகோஸ்", "லாக்டோஸ்", "சுக்ரோஸ்", "மால்டோஸ்"], "answer": 1, "ex": "பாலில் லாக்டோஸ் உள்ளது." },
      { "section": "அறிவியல்", "question": "மீன்களின் சுவாச உறுப்பு எது?", "options": ["நுரையீரல்", "தோல்", "செவுள்கள் (Gills)", "மூச்சுக்குழல்"], "answer": 2, "ex": "மீன்கள் செவுள்கள் மூலம் சுவாசிக்கின்றன." },
      { "section": "அறிவியல்", "question": "பூச்சிகளை உண்ணும் தாவரம் எது?", "options": ["கஸ்கியூட்டா", "நெப்பந்தஸ்", "விஸ்கம்", "காளான்"], "answer": 1, "ex": "நெப்பந்தஸ் பூச்சிகளை உணவாகக் கொள்ளும்." },
      { "section": "அறிவியல்", "question": "முதன்முதலில் கண்டுபிடிக்கப்பட்ட நுண்ணுயிர்க்கொல்லி (Antibiotic) எது?", "options": ["பெンசிலின்", "ஸ்ட்ரெப்டோமைசின்", "அமாக்சிசிலின்", "டெட்ராசைக்ளின்"], "answer": 0, "ex": "அெக்சாண்டர் பிளம்மிங் பென்சிலினை கண்டறிந்தார்." },
      { "section": "அறிவியல்", "question": "மனித இதயத்தில் எத்தனை அறைகள் உள்ளன?", "options": ["2", "3", "4", "5"], "answer": 2, "ex": "மனித இதயத்தில் நான்கு அறைகள் உள்ளன." },
      { "section": "அறிவியல்", "question": "மின்காந்த தூண்டலைக் கண்டுபிடித்தவர் யார்?", "options": ["மைக்கேல் ஃபாரடே", "தாமஸ் ஆல்வா எடிசன்", "ஐசக் நியூட்டன்", "ஆல்பர்ட் ஐன்ஸ்டீன்"], "answer": 0, "ex": "மைக்கேல் ஃபாரடே இதனை கண்டறிந்தார்." },
      { "section": "அறிவியல்", "question": "புவியீர்ப்பு முடுக்கத்தின் (g) சராசரி மதிப்பு என்ன?", "options": ["9.8 m/s2", "8.9 m/s2", "10.5 m/s2", "9.8 cm/s2"], "answer": 0, "ex": "சுமார் 9.8 மீ/வி2." },
      { "section": "அறிவியல்", "question": "வாகனங்களில் பின்னால் வரும் வண்டிகளைப் பார்க்கப் பயன்படும் ஆடி எது?", "options": ["குழி ஆடி", "குவி ஆடி (Convex mirror)", "சமதள ஆடி", "கோளக ஆடி"], "answer": 1, "ex": "நேரான சிறு பிம்பத்தைக் காட்டும் குவி ஆடி." },
      { "section": "அறிவியல்", "question": "'உலர்பனிக்கட்டி' (Dry Ice) என அழைக்கப்படுவது எது?", "options": ["திட ஆக்சிஜன்", "திட நைட்ரஜன்", "திட கார்பன் டை ஆக்சைடு", "குளிர்ந்த நீர்"], "answer": 2, "ex": "திட நிலை CO2 உலர்பனிக்கட்டி எனப்படும்." },
      { "section": "அறிவியல்", "question": "பட்டுப்புழு வளர்ப்பு எவ்வாறு அழைக்கப்படுகிறது?", "options": ["செரிகல்ச்சர் (Sericulture)", "எபிகல்ச்சர்", "பிசிகல்ச்சர்", "ஹார்டிகல்ச்சர்"], "answer": 0, "ex": "செரிகல்ச்சர் என்பது பட்டுப்புழு வளர்ப்பு." },
      { "section": "அறிவியல்", "question": "மனித உடலின் மிகப்பெரிய சுரப்பி எது?", "options": ["பிட்யூட்டரி", "தைராய்டு", "கணையம்", "கல்லீரல்"], "answer": 3, "ex": "கல்லீரல் மிகப்பெரிய சுரப்பியாகும்." },
      { "section": "அறிவியல்", "question": "காசநோயை (TB) ஏற்படுத்தும் பாக்டீரியா எது?", "options": ["சால்மோனெல்லா டைபி", "விப்ரியோ காலரே", "மைக்கோபாக்டீரியம் டியூபர்குளோசிஸ்", "பிளாஸ்மோடியம்"], "answer": 2, "ex": "மைக்கோபாக்டீரியம் டியூபர்குளோசிஸ் TB-ஐ உண்டாக்குகிறது." },
      { "section": "அறிவியல்", "question": "தாவரங்களில் நீரை கடத்தும் திசு எது?", "options": ["புளோயம்", "சைலம்", "பாரன்கைமா", "கோலன்கைமா"], "answer": 1, "ex": "சைலம் நீரை கடத்துகிறது, புளோயம் உணவை கடத்துகிறது." },
      { "section": "அறிவியல்", "question": "இரத்த சிவப்பணுக்களின் (RBC) வாழ்நாள் எவ்வளவு?", "options": ["120 நாட்கள்", "100 நாட்கள்", "3-4 வாரங்கள்", "1 வருடம்"], "answer": 0, "ex": "RBC சுார் 120 நாட்கள் உயிர் வாழும்." },
      { "section": "அறிவியல்", "question": "பூமியைச் சுற்றும் முதல் செயற்கைக்கோளான 'ஸ்புட்னிக் 1' ஐ செலுத்திய நாடு எது?", "options": ["அமெரிக்கா", "சோவியத் ரஷ்யா", "இந்தியா", "சீனா"], "answer": 1, "ex": "சோவியத் ரஷ்யா 1957-ல் செலுத்தியது." }
    ]
  }
}
