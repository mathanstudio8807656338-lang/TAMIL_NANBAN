  "title": "திருப்புதல் தேர்வு 1 - கணிதம் (Maths)",
  "sections": [
    {
      "title": "கணிதம் (Maths) - சூத்திரங்கள்",
      "content": "இயற்கணிதம், வாழ்வியல் கணிதம் மற்றும் அளவியல் பகுதிகளில் உள்ள சூத்திரங்களை ஒருமுறை நினைவுபடுத்திக் கொள்ளவும். $a^2 + b^2$ போன்ற எளிய வடிவங்கள் முக்கியம்."
    }
  ],
  "quiz": {
    "questions": [
      { "section": "கணிதம்", "question": "12, 15, 20 ஆகிய எண்களின் மீ.சி.ம (LCM) காண்க.", "options": ["30", "45", "60", "120"], "answer": 2, "ex": "12, 15, 20 ஆகிய எண்களால் வகுபடக்கூடிய மிகச்சிறிய எண் 60." },
      { "section": "கணிதம்", "question": "(-5) x (-4) x (-2) இன் மதிப்பு என்ன?", "options": ["40", "$-40$", "11", "$-11$"], "answer": 1, "ex": "$(-5) \\times (-4) = +20$. பின்னர் $(+20) \\times (-2) = -40$." },
      { "section": "கணிதம்", "question": "3/4 ஐ சதவீதமாக மாற்றுக.", "options": ["50%", "75%", "25%", "100%"], "answer": 1, "ex": "$3/4 \\times 100 = 75\\% $." },
      { "section": "கணிதம்", "question": "ஒரு வட்டத்தின் ஆரம் 7 cm எனில், அதன் பரப்பளவு காண்க.", "options": ["154 cm2", "44 cm2", "144 cm2", "314 cm2"], "answer": 0, "ex": "$A = \\pi r^2 = (22/7) \\times 7^2 = 154$." },
      { "section": "கணிதம்", "question": "2x + 5 = 15 என்ற சமன்பாட்டில் x இன் மதிப்பு என்ன?", "options": ["5", "10", "20", "2"], "answer": 0, "ex": "$2x = 10 \\Rightarrow x = 5$." },
      { "section": "கணிதம்", "question": "ஒரு முக்கோணத்தின் மூன்று கோணங்களின் கூடுதல் என்ன?", "options": ["90°", "180°", "360°", "270°"], "answer": 1, "ex": "எந்த முக்கோணத்திலும் கூடுதல் 180° ஆகும்." },
      { "section": "கணிதம்", "question": "70° கோணத்தின் நிரப்புக் கோணம் (Complementary Angle) என்ன?", "options": ["110°", "20°", "90°", "290°"], "answer": 1, "ex": "$90 - 70 = 20$." },
      { "section": "கணிதம்", "question": "ஒருவர் ₹500 க்கு வாங்கி ₹600 க்கு விற்றால் இலாப சதவீதம் என்ன?", "options": ["10%", "20%", "25%", "50%"], "answer": 1, "ex": "இலாபம் 100. $(100/500) \\times 100 = 20\\%$." },
      { "section": "கணிதம்", "question": "$3^4 \\div 3^2$ இன் மதிப்பு என்ன?", "options": ["$3^6$", "$3^2$", "$3^8$", "1"], "answer": 1, "ex": "$3^{4-2} = 3^2 = 9$." },
      { "section": "கணிதம்", "question": "10, 15, 20, 25, 30 ஆகிய எண்களின் சராசரி (Mean) காண்க.", "options": ["20", "25", "15", "100"], "answer": 0, "ex": "கூடுதல் 100 / 5 = 20." },
      { "section": "கணிதம்", "question": "a:b = 2:3 மற்றும் b:c = 3:4 எனில் a:b:c இன் விகிதம் என்ன?", "options": ["2:3:4", "4:3:2", "2:4:3", "1:2:3"], "answer": 0, "ex": "b சமமாக இருப்பதால் 2:3:4." },
      { "section": "கணிதம்", "question": "₹10,000 அசலுக்கு 5% வட்டியில் 2 ஆண்டுகளுக்கு தனிவட்டி என்ன?", "options": ["₹1000", "₹500", "₹1500", "₹2000"], "answer": 0, "ex": "$SI = PNR/100 = (10000 \\times 2 \\times 5)/100 = 1000$." },
      { "section": "கணிதம்", "question": "செவ்வகத்தின் நீளம் 8m, அகலம் 5m எனில் அதன் சுற்றளவு என்ன?", "options": ["40m", "13m", "26m", "20m"], "answer": 2, "ex": "$2(l+b) = 2(8+5) = 26$." },
      { "section": "கணிதம்", "question": "$a^2 - b^2$ என்பதன் விரிவாக்கம் என்ன?", "options": ["$(a-b)^2$", "$(a+b)(a-b)$", "$a^2-2ab+b^2$", "$a^2+b^2$"], "answer": 1, "ex": "இது ஒரு முற்றுரிமை." },
      { "section": "கணிதம்", "question": "2, 4, 4, 5, 4, 6, 4, 7 என்ற தரவுகளின் முகடு (Mode) என்ன?", "options": ["2", "4", "5", "7"], "answer": 1, "ex": "4 அதிக முறை வந்துள்ளது." },
      { "section": "கணிதம்", "question": "கனசதுரத்தின் பக்க அளவு 3cm எனில் அதன் கனஅளவு என்ன?", "options": ["9 cm3", "27 cm3", "18 cm3", "6 cm3"], "answer": 1, "ex": "$a^3 = 3^3 = 27$." },
      { "section": "கணிதம்", "question": "0.75 என்ற தசம எண்ணை பின்னமாக மாற்றுக.", "options": ["1/4", "3/4", "1/2", "3/5"], "answer": 1, "ex": "$75/100 = 3/4$." },
      { "section": "கணிதம்", "question": "110° கோணத்தின் மிகைநிரப்புக் கோணம் (Supplementary Angle) என்ன?", "options": ["70°", "90°", "110°", "180°"], "answer": 0, "ex": "$180 - 110 = 70$." },
      { "section": "கணிதம்", "question": "பித்தாகரஸ் தேற்றத்தின்படி கர்ணத்தின் வர்க்கம் எதற்குச் சமம்?", "options": ["இரு பக்கங்களின் கூடுதல்", "இரு பக்கங்களின் வர்க்கங்களின் கூடுதல்", "இரு பக்கங்களின் பெருக்கம்", "இரு பக்கங்களின் வர்க்கங்களின் கழித்தல்"], "answer": 1, "ex": "$c^2 = a^2 + b^2$." },
      { "section": "கணிதம்", "question": "$x^0$ இன் மதிப்பு என்ன? (x != 0)", "options": ["x", "0", "1", "inf"], "answer": 2, "ex": "எந்த எண்ணின் அடுக்கு பூஜ்ஜியம் என்றாலும் அதன் மதிப்பு 1." },
      { "section": "கணிதம்", "question": "சதுரத்தின் மூலைவிட்டம் 10cm எனில், அதன் பரப்பளவு காண்க.", "options": ["100 cm2", "50 cm2", "25 cm2", "20 cm2"], "answer": 1, "ex": "$(1/2) \\times d^2 = (1/2) \\times 100 = 50$." },
      { "section": "கணிதம்", "question": "-7 இன் கூட்டல் எதிர்மறை (Additive Inverse) what?", "options": ["7", "1/7", "-1/7", "0"], "answer": 0, "ex": "$(-7) + 7 = 0$." },
      { "section": "கணிதம்", "question": "வட்ட விளக்கப்படத்தின் மையக் கோணங்களின் கூடுதல் என்ன?", "options": ["180°", "90°", "360°", "270°"], "answer": 2, "ex": "முழு வட்டத்தின் கோணம் 360°." },
      { "section": "கணிதம்", "question": "முதல் 5 இயல் எண்களின் இடைநிலை அளவு (Median) என்ன?", "options": ["2", "3", "4", "5"], "answer": 1, "ex": "1, 2, 3, 4, 5 - நடுவில் இருப்பது 3." },
      { "section": "கணிதம்", "question": "x = 2 எனில், $3x^2 + 2x - 5$ இன் மதிப்பு என்ன?", "options": ["11", "9", "15", "21"], "answer": 0, "ex": "$3(4) + 4 - 5 = 11$." },
      { "section": "கணிதம்", "question": "ஒரு எண்ணின் 3 மடங்கிலிருந்து 5 ஐக் கழித்தால் 16 கிடைக்கிறது எனில் அவ்வெண் யாது?", "options": ["5", "6", "7", "8"], "answer": 2, "ex": "$3x - 5 = 16 \\Rightarrow 3x = 21 \\Rightarrow x = 7$." },
      { "section": "கணிதம்", "question": "$(a^m)^n$ என்பதற்குச் சமமானது எது?", "options": ["$a^{m+n}$", "$a^{m-n}$", "$a^{mn}$", "$a^{m/n}$"], "answer": 2, "ex": "அடுக்குகளைப் பெருக்க வேண்டும்." },
      { "section": "கணிதம்", "question": "இருசமபக்க முக்கோணத்தில் எத்தனை கோணங்கள் சமமாக இருக்கும்?", "options": ["1", "2", "3", "0"], "answer": 1, "ex": "இரு பக்கங்களுக்கு எதிரில் உள்ள இரு கோணங்கள் சமம்." },
      { "section": "கணிதம்", "question": "மீப்பெரு பொது காரணி (HCF) காண்க: 16, 24", "options": ["4", "8", "16", "48"], "answer": 1, "ex": "8 இரண்டு எண்களையும் வகுக்கும் மிகப்பெரிய எண்." },
      { "section": "கணிதம்", "question": "சாய் சதுரத்தின் மூலைவிட்டங்கள் d1=6cm, d2=8cm எனில் அதன் பரப்பளவு என்ன?", "options": ["48 cm2", "24 cm2", "14 cm2", "100 cm2"], "answer": 1, "ex": "$(1/2) \\times 6 \\times 8 = 24$." }
    ]
  }
